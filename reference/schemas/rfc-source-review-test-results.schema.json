{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/rfc-source-review-test-results.schema.json",
  "title": "RFC Repository Source Review Test Results",
  "type": "object",
  "required": [
    "canonical_repository",
    "summary",
    "results"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "summary": {
      "type": "object"
    },
    "results": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "required": [
          "test_id",
          "source_blob_sha",
          "result",
          "claim_boundary"
        ],
        "properties": {
          "result": {
            "const": "Pass"
          }
        }
      }
    }
  }
}
