{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/rfc-review-checklist-registry.schema.json",
  "title": "Ming Foundation RFC Review Checklist Registry",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "canonical_repository",
    "checklists"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "checklists": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "checklist_id",
          "source_document",
          "source_blob_sha",
          "review_state",
          "promotion_recommendation",
          "dimensions"
        ],
        "properties": {
          "checklist_id": {
            "pattern": "^CHECK-RFC-[0-9]{4}$"
          },
          "source_document": {
            "pattern": "^RFC-[0-9]{4}$"
          },
          "source_blob_sha": {
            "pattern": "^[0-9a-f]{40}$"
          },
          "review_state": {
            "enum": [
              "Prepared",
              "InReview",
              "Complete",
              "Superseded"
            ]
          },
          "promotion_recommendation": {
            "enum": [
              "RetainProposed",
              "AdvanceToReview",
              "AdvanceToCandidate",
              "Revise",
              "Withdraw"
            ]
          },
          "dimensions": {
            "type": "array",
            "minItems": 9,
            "items": {
              "type": "object",
              "required": [
                "dimension",
                "questions",
                "required_disposition"
              ],
              "properties": {
                "dimension": {
                  "type": "string"
                },
                "questions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "required_disposition": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
