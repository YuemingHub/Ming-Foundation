{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/named-accountability-public-register.schema.json",
  "title": "Named Accountability Public Register",
  "type": "object",
  "required": [
    "canonical_repository",
    "identity_boundary",
    "overall_state",
    "roles",
    "summary"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "overall_state": {
      "const": "FrameworkCompleteNoNamedAssignees"
    },
    "roles": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "role_id",
          "public_accountability_id",
          "nomination_state",
          "restricted_identity_ref",
          "public_display_name",
          "acceptance_state",
          "qualification_check",
          "conflict_check",
          "independence_check",
          "activation_authority"
        ],
        "properties": {
          "public_accountability_id": {
            "pattern": "^RA-[0-9]{2}$"
          },
          "nomination_state": {
            "const": "NotNominated"
          },
          "restricted_identity_ref": {
            "type": "null"
          },
          "public_display_name": {
            "type": "null"
          },
          "acceptance_state": {
            "const": "NotAccepted"
          },
          "activation_authority": {
            "const": false
          }
        }
      }
    },
    "summary": {
      "type": "object"
    }
  }
}
