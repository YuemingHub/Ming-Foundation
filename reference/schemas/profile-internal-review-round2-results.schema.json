{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/profile-internal-review-round2-results.schema.json",
  "title": "Profile Internal Review Round 2 Results",
  "type": "object",
  "required": [
    "canonical_repository",
    "review_scope",
    "summary",
    "results"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "review_scope": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "results": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "review_id",
          "source_document",
          "source_blob_sha",
          "source_version",
          "review_state",
          "dimensions",
          "overall_disposition",
          "promotion_recommendation"
        ],
        "properties": {
          "review_state": {
            "const": "Complete"
          },
          "overall_disposition": {
            "const": "InternallyReadyPendingAffectedPersonReview"
          },
          "promotion_recommendation": {
            "const": "RetainProposed"
          }
        }
      }
    }
  }
}
