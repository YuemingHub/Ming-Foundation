{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/review-role-assignment-registry.schema.json",
  "title": "Review Role Assignment Registry",
  "type": "object",
  "required": [
    "canonical_repository",
    "assignment_state",
    "roles",
    "summary"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "assignment_state": {
      "const": "Unassigned"
    },
    "roles": {
      "type": "array",
      "minItems": 8
    },
    "summary": {
      "type": "object"
    }
  }
}
