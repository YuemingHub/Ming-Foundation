{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/review-operational-activation.schema.json",
  "title": "Review Operational Activation Register",
  "type": "object",
  "required": [
    "canonical_repository",
    "activation_state",
    "scheduling_authorized",
    "recruitment_authorized",
    "sessions_authorized",
    "roles",
    "approvals",
    "environment",
    "summary",
    "human_review_activation_state",
    "synthetic_pilot_authorized",
    "synthetic_pilot_execution_state"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "activation_state": {
      "const": "SyntheticPilotOnly"
    },
    "scheduling_authorized": {
      "const": false
    },
    "recruitment_authorized": {
      "const": false
    },
    "sessions_authorized": {
      "const": false
    },
    "roles": {
      "type": "array",
      "minItems": 8
    },
    "approvals": {
      "type": "array",
      "minItems": 7
    },
    "environment": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "human_review_activation_state": {
      "const": "NotActivated"
    },
    "synthetic_pilot_authorized": {
      "const": true
    },
    "synthetic_pilot_execution_state": {
      "const": "Complete"
    }
  }
}
