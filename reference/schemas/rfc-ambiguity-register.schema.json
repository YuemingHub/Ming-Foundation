{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/rfc-ambiguity-register.schema.json",
  "title": "Ming Foundation RFC Ambiguity Register",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "canonical_repository",
    "ambiguities"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ambiguity_id",
          "source_document",
          "source_section",
          "title",
          "question",
          "severity",
          "affected_requirements",
          "recommended_resolution",
          "status"
        ],
        "properties": {
          "ambiguity_id": {
            "pattern": "^AMB-[0-9]{4}$"
          },
          "source_document": {
            "pattern": "^RFC-[0-9]{4}$"
          },
          "severity": {
            "enum": [
              "BlockingForCandidate",
              "CandidateClarification",
              "Editorial"
            ]
          },
          "affected_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "pattern": "^RFC-[0-9]{4}-R[0-9]{3}$"
            }
          },
          "status": {
            "enum": [
              "Open",
              "Resolved",
              "Superseded"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
