{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/cp2-protocol-applicability-matrix.schema.json",
  "title": "CP2 Protocol Applicability Matrix",
  "type": "object",
  "required": [
    "canonical_repository",
    "overall_state",
    "protocols",
    "summary"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "overall_state": {
      "const": "ApplicabilityDefinedApprovalsOutstanding"
    },
    "protocols": {
      "type": "array",
      "minItems": 7
    },
    "summary": {
      "type": "object"
    }
  }
}
