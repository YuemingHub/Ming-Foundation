{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/residual-profile-registry.schema.json",
  "title": "Residual Profile Registry",
  "type": "object",
  "required": [
    "canonical_repository",
    "summary",
    "profiles"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "summary": {
      "type": "object"
    },
    "profiles": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "status",
          "version",
          "ambiguity_refs",
          "requirement_refs",
          "residual_item_refs",
          "source_blob_sha",
          "internal_review_state",
          "internal_review_ref",
          "internal_review_record",
          "disposition",
          "affected_person_review_state"
        ],
        "properties": {
          "id": {
            "pattern": "^PROF-[0-9]{4}$"
          },
          "status": {
            "const": "Proposed"
          },
          "source_blob_sha": {
            "pattern": "^[0-9a-f]{40}$"
          },
          "internal_review_state": {
            "const": "Complete"
          },
          "internal_review_ref": {
            "type": "string"
          },
          "internal_review_record": {
            "pattern": "^GOV-[0-9]{4}$"
          },
          "disposition": {
            "const": "ReviseAndRetainProposed"
          },
          "affected_person_review_state": {
            "const": "PreparedNotExecuted"
          }
        }
      }
    }
  }
}
