{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/synthetic-pilot-scenarios.schema.json",
  "title": "Synthetic Pilot Scenarios",
  "type": "object",
  "required": [
    "canonical_repository",
    "data_policy",
    "scenarios",
    "summary"
  ],
  "properties": {
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "data_policy": {
      "const": "SyntheticOnly"
    },
    "scenarios": {
      "type": "array",
      "minItems": 12
    },
    "summary": {
      "type": "object"
    }
  }
}
