{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mingos.cn/schemas/rfc-requirement-registry.schema.json",
  "title": "Ming Foundation RFC Requirement Registry",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "authority",
    "canonical_repository",
    "source_documents",
    "requirements"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "registry_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "canonical_repository": {
      "const": "YuemingHub/Ming-Foundation"
    },
    "source_repository_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "registry_version": {
      "type": "string"
    },
    "authority": {
      "type": "object",
      "required": [
        "normative_source",
        "registry_role",
        "governing_decision"
      ],
      "properties": {
        "normative_source": {
          "type": "string"
        },
        "registry_role": {
          "type": "string"
        },
        "governing_decision": {
          "const": "ADR-0010"
        }
      },
      "additionalProperties": false
    },
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "status",
          "version"
        ],
        "properties": {
          "id": {
            "pattern": "^RFC-[0-9]{4}$"
          },
          "path": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "source_blob_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "fidelity_review_record": {
            "type": "string"
          },
          "review_state": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "requirement_id",
          "source_document",
          "source_section",
          "kind",
          "normative_level",
          "statement",
          "implementation_neutral",
          "external_evidence_required",
          "verification_methods",
          "evidence_types",
          "acceptance_test_refs",
          "fidelity_review",
          "internal_review_ref"
        ],
        "properties": {
          "requirement_id": {
            "pattern": "^RFC-[0-9]{4}-R[0-9]{3}$"
          },
          "source_document": {
            "pattern": "^RFC-[0-9]{4}$"
          },
          "source_section": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "explicit_normative",
              "conformance_test",
              "design_constraint"
            ]
          },
          "normative_level": {
            "enum": [
              "MUST",
              "MUST_NOT",
              "SHOULD",
              "SHOULD_NOT",
              "MAY",
              "UNSPECIFIED"
            ]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "implementation_neutral": {
            "type": "boolean"
          },
          "external_evidence_required": {
            "type": "boolean"
          },
          "verification_methods": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "evidence_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_test_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "pattern": "^RFC-[0-9]{4}-AT[0-9]{3}$"
            }
          },
          "fidelity_review": {
            "type": "object",
            "required": [
              "state",
              "reviewed_at",
              "reviewed_against_commit",
              "review_record",
              "ambiguity_refs"
            ],
            "properties": {
              "state": {
                "enum": [
                  "Confirmed",
                  "NeedsCorrection",
                  "Unverifiable"
                ]
              },
              "reviewed_at": {
                "type": "string"
              },
              "reviewed_against_commit": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              },
              "review_record": {
                "type": "string"
              },
              "ambiguity_refs": {
                "type": "array",
                "items": {
                  "pattern": "^AMB-[0-9]{4}$"
                }
              }
            },
            "additionalProperties": false
          },
          "internal_review_ref": {
            "type": "string",
            "pattern": "^IRR-RFC-[0-9]{4}-[0-9]{8}$"
          },
          "current_source_state": {
            "enum": [
              "Confirmed",
              "RevisedPendingReview",
              "NeedsCorrection",
              "Unverifiable",
              "LegacyIndexPendingRebaseline"
            ]
          },
          "current_source_version": {
            "type": "string"
          },
          "current_source_blob_sha": {
            "pattern": "^[0-9a-f]{40}$"
          },
          "current_source_review_record": {
            "type": "string"
          },
          "round2_review_ref": {
            "type": "string",
            "pattern": "^IRR2-RFC-[0-9]{4}-[0-9]{8}$"
          }
        },
        "additionalProperties": false
      }
    },
    "fidelity_review": {
      "type": "object"
    },
    "internal_review": {
      "type": "object"
    },
    "current_fidelity_status": {
      "type": "object"
    },
    "round2_review": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
